		"@types/three": "^0.183.1",
		"koota": "^0.6.5",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sql.js": "^1.14.1",
		"three": "^0.183.2",
		"tone": "^15.1.22",
		"yuka": "^0.7.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
