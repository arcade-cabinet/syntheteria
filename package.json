{
	"name": "syntheteria",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:poc": "webpack serve --config webpack.poc.config.ts --port 3001 --mode=development",
		"build": "tsc -b && vite build",
		"build:poc": "webpack --config webpack.poc.config.ts --mode=production",
		"preview": "vite preview",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"test:browser": "vitest --config vitest.browser.config.ts run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"tsc": "tsc -b --noEmit",
		"verify": "pnpm lint && pnpm tsc"
	},
	"dependencies": {
		"@babylonjs/core": "^8.0.0",
		"@babylonjs/gui": "^8.0.0",
		"@babylonjs/havok": "^1.3.10",
		"@capacitor/android": "^8.2.0",
		"@capacitor/cli": "^8.2.0",
		"@capacitor/core": "^8.2.0",
		"@capacitor/ios": "^8.2.0",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"@types/three": "^0.183.1",
		"koota": "^0.6.5",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"reactylon": "^3.0.0",
		"sql.js": "^1.14.1",
		"three": "^0.183.2",
		"tone": "^15.1.22",
		"yuka": "^0.7.8"
	},
	"devDependencies": {
		"@babel/core": "^7.17.3",
		"@babel/preset-env": "^7.24.3",
		"@babel/preset-react": "^7.26.3",
		"@babel/preset-typescript": "^7.24.1",
		"@babel/register": "^7.23.7",
		"@biomejs/biome": "^2.4.8",
		"@playwright/test": "^1.58.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/webpack": "^5.28.5",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser-playwright": "^4.1.1",
		"babel-loader": "^10.0.0",
		"babel-plugin-reactylon": "^1.0.0",
		"css-loader": "^6.10.0",
		"fork-ts-checker-webpack-plugin": "^9.0.3",
		"html-webpack-plugin": "^5.5.0",
		"jsdom": "^29.0.1",
		"style-loader": "^4.0.0",
		"ts-loader": "^9.4.1",
		"typescript": "~6.0.2",
		"url-loader": "^4.1.1",
		"vite": "^8.0.2",
		"vite-static-assets-plugin": "^1.2.2",
		"vitest": "^4.1.1",
		"webpack": "^5.91.0",
		"webpack-cli": "^5.1.4",
		"webpack-dev-server": "^5.0.4"
	}
