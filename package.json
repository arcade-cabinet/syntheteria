		"postcss": "^8.4.49",
		"playwright": "^1.49.0",
		"react-dom": "19.2.0",
		"react-native-web": "^0.21.2",
		"react-test-renderer": "19.2.0",
		"sharp": "^0.34.5",
		"sql.js": "^1.14.1",
		"tailwindcss": "^3.4.17",
		"ts-jest": "^29.4.6",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
