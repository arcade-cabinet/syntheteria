{
  "expo": {
    "name": "Syntheteria",
    "slug": "syntheteria",
    "version": "0.1.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "scheme": "syntheteria",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-sqlite"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
