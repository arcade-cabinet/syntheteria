{
	"name": "app",
	"version": "1.0.0",
	"main": "expo-router/entry",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"cap:sync": "cap sync",
		"cap:ios": "cap run ios",
		"cap:android": "cap run android",
		"start": "expo start",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"build:web": "pnpm db:build:foundation && expo export --platform web && node -e \"require('fs').mkdirSync('dist/assets',{recursive:true}); require('fs').copyFileSync('assets/coi-serviceworker.js','dist/assets/coi-serviceworker.js')\"",
		"test": "jest",
		"test:vitest": "vitest run",
		"test:vitest:watch": "vitest",
		"test:vitest:coverage": "vitest run --coverage",
		"test:ct": "playwright test -c playwright-ct.config.ts",
		"test:e2e": "playwright test -c playwright.e2e.config.ts",
		"test:all": "pnpm test:vitest && pnpm test",
		"verify": "pnpm lint && pnpm tsc && pnpm test && pnpm test:ct",
		"tsc": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:build:foundation": "tsx scripts/build-foundation-db.ts",
		"city:ingest": "tsx scripts/ingest-city-models.ts",
		"assets:icons": "python3 scripts/generate-brand-icons.py",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:fix:unsafe": "biome check --write --unsafe ."
	},
	"dependencies": {
		"@capacitor-community/sqlite": "^8",
		"@capacitor/core": "^8.2.0",
		"@react-native/assets-registry": "^0.84.1",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"coi-serviceworker": "^0.1.7",
		"connect": "^3.7.0",
		"drizzle-orm": "^0.45.1",
		"expo": "~55.0.6",
		"expo-asset": "^55.0.8",
		"expo-device": "~55.0.9",
		"expo-gl": "~55.0.9",
		"expo-modules-core": "^55.0.15",
		"expo-router": "^55.0.5",
		"expo-splash-screen": "~55.0.10",
		"expo-sqlite": "~55.0.10",
		"expo-status-bar": "~55.0.4",
		"its-fine": "^2.0.0",
		"koota": "^0.6.5",
		"lucide-react-native": "^0.577.0",
		"miniplex": "^2.0.0",
		"nativewind": "^4.2.2",
		"react": "19.2.0",
		"react-native": "0.83.2",
		"react-native-css-interop": "^0.2.2",
		"react-native-reanimated": "4.2.1",
		"react-native-svg": "^15.15.3",
		"react-native-worklets": "0.7.2",
		"react-use-measure": "^2.1.7",
		"scheduler": "^0.27.0",
		"suspend-react": "^0.1.3",
		"three": "^0.183.2",
		"tone": "^15.1.22",
		"tslib": "^2.8.1",
		"yuka": "^0.7.8",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/generator": "^7.29.1",
		"@babel/plugin-transform-react-jsx": "^7.28.6",
