{
  "_comment": "4-path victory framework. See docs/design/gameplay/VICTORY_PATHS.md for full design doc. These 4 paths organize the 8 existing victory conditions and add the Religious/Philosophical path with per-faction cult mechanics.",

  "paths": {
    "technical_mastery": {
      "displayName": "Technical Mastery",
      "subtitle": "Logic, research, build",
      "primaryResource": "compute",
      "victoryConditions": ["technology"],
      "description": "Research all tech tiers, build apex structures, unlock the Convergence Device.",
      "governorBias": {
        "signal_choir": 1.3,
        "reclaimers": 1.0,
        "volt_collective": 0.9,
        "iron_creed": 0.8
      }
    },
    "subjugation": {
      "displayName": "Subjugation",
      "subtitle": "Force, conquest, dominance",
      "primaryResource": "military_units",
      "victoryConditions": ["domination", "survival"],
      "description": "Conquer all territories, destroy rival bases, be the last faction standing.",
      "governorBias": {
        "volt_collective": 1.4,
        "iron_creed": 1.1,
        "reclaimers": 0.9,
        "signal_choir": 0.7
      }
    },
    "social_networking": {
      "displayName": "Social Networking",
      "subtitle": "Diplomacy, trade, alliances",
      "primaryResource": "influence",
      "victoryConditions": ["diplomatic", "economic", "colonial"],
      "description": "Build trade networks, form alliances, achieve colonial objectives, dominate economically.",
      "governorBias": {
        "reclaimers": 1.2,
        "signal_choir": 1.1,
        "iron_creed": 1.0,
        "volt_collective": 0.7
      }
    },
    "religious_philosophical": {
      "displayName": "Religious / Philosophical",
      "subtitle": "Faith, ideology, conversion",
      "primaryResource": "faith",
      "victoryConditions": ["enlightenment", "integration", "story"],
      "description": "Accumulate Faith through shrines, convert enemy units to your ideology, achieve Enlightenment.",
      "governorBias": {
        "reclaimers": 0.9,
        "volt_collective": 0.8,
        "signal_choir": 1.2,
        "iron_creed": 1.1
      }
    }
  },

  "faithSystem": {
    "_comment": "Faith/Ideology resource for the Religious/Philosophical path",
    "maxFaith": 2000,
    "enlightenmentThreshold": 1000,
    "enlightenmentMinReason": 200,
    "faithDecayPerTick": 0,
    "faithGenerationSources": {
      "shrine": 1.0,
      "temple": 3.0,
      "grand_cathedral": 8.0,
      "conversion_event": 20,
      "doctrine_unlock": 50,
      "storm_event_volt": 5.0
    },
    "influenceZones": {
      "shrine": { "radius": 8, "faithPressurePerTick": 0.1 },
      "temple": { "radius": 15, "faithPressurePerTick": 0.3 },
      "grand_cathedral": { "radius": 25, "faithPressurePerTick": 0.7 }
    },
    "conversionMechanics": {
      "conversionActionRange": 6,
      "faithPressureToVulnerable": 50,
      "conversionChanceBase": 0.15,
      "conversionChancePerFaithLevel": 0.02,
      "conversionTimeSeconds": 10,
      "sameFactionImmune": true,
      "_note": "Units with high Reason (compute > 100) resist conversion by 50%"
    }
  },

  "victoryEnlightenment": {
    "_comment": "Enlightenment Victory condition — Religious/Philosophical path apex",
    "faithRequired": 1000,
    "reasonMinimum": 200,
    "grandCathedralRequired": true,
    "unitsConverted": 20,
    "doctrinesUnlocked": 10,
    "cultLeaderSurvived": true,
    "holdDurationSeconds": 300,
    "_note": "The 300-second hold prevents instant win on meeting conditions; requires sustained presence"
  },

