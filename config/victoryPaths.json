  "reasonSystem": {
    "_comment": "Reason/Logic resource — accumulates via compute buildings and tech research",
    "maxReason": 2000,
    "reasonGenerationSources": {
      "compute_building_per_tick": 0.5,
      "research_complete": 30,
      "data_cache_found": 10,
      "hack_success": 5
    },
    "_note": "Reason is NOT a counter to Faith — both can max. High Reason reduces conversion vulnerability."
  }
