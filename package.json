{
	"name": "app",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:vitest": "vitest run",
		"test:vitest:watch": "vitest",
		"test:vitest:coverage": "vitest run --coverage",
		"test:ct": "vitest run --config vitest.browser.config.ts",
		"test:ct:watch": "vitest --config vitest.browser.config.ts",
		"test:e2e": "playwright test -c playwright.e2e.config.ts",
		"test:all": "pnpm test:vitest && pnpm test:ct",
		"verify": "pnpm lint && pnpm tsc && pnpm test:vitest",
		"check-imports": "bash scripts/check-imports.sh",
		"verify:with-ct": "pnpm verify && pnpm test:ct",
		"tsc": "tsc --noEmit",
		"db:build:foundation": "tsx scripts/build-foundation-db.ts",
		"city:ingest": "tsx scripts/ingest-city-models.ts",
		"assets:icons": "python3 scripts/generate-brand-icons.py",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"cap:sync": "npx cap sync",
		"cap:sync:android": "npx cap sync android",
		"cap:sync:ios": "npx cap sync ios",
		"build:android": "pnpm build && npx cap sync android",
		"build:ios": "pnpm build && npx cap sync ios",
		"build:web": "pnpm build",
		"lint:fix:unsafe": "biome check --write --unsafe ."
	},
	"dependencies": {
		"@capacitor-community/sqlite": "^8",
		"@capacitor/android": "^8.2.0",
		"@capacitor/core": "^8.2.0",
		"@capacitor/ios": "^8.2.0",
		"@enable3d/phaser-extension": "^0.26.1",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"jeep-sqlite": "^2.8.0",
		"koota": "^0.6.5",
		"lucide-react": "^0.577.0",
		"phaser": "^3.90.0",
		"react": "19.2.0",
		"three": "^0.183.2",
		"tone": "^15.1.22",
		"troika-three-text": "^0.52.4",
		"tslib": "^2.8.1",
		"yuka": "^0.7.8",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/generator": "^7.29.1",
		"@babel/plugin-transform-react-jsx": "^7.28.6",
		"@babel/runtime": "^7.28.6",
		"@babel/traverse": "^7.29.0",
		"@babel/types": "^7.29.0",
		"@biomejs/biome": "^2.4.6",
		"@capacitor/cli": "^8.2.0",
		"@playwright/test": "^1.49.0",
		"@react-three/test-renderer": "^9.1.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.4.0",
		"@types/react": "~19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/sql.js": "^1.4.9",
		"@types/three": "^0.183.1",
		"@types/yuka": "^0.7.4",
		"@vitejs/plugin-react": "^4.7.0",
		"@vitest/browser": "^4.1.0",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"autoprefixer": "^10.4.27",
		"jsdom": "^28.1.0",
		"playwright": "^1.49.0",
		"postcss": "^8.4.49",
		"react-dom": "19.2.0",
		"sharp": "^0.34.5",
		"sql.js": "^1.14.1",
		"tailwindcss": "^3.4.17",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"vite": "^6.4.1",
		"vite-plugin-glsl": "^1.5.6",
		"vitest": "^4.1.0",
		"vitest-browser-react": "^2.1.0"
	},
	"private": true
}
