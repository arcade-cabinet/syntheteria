# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
package-lock.json
npm-shrinkwrap.json

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# coverage
coverage/

# generated native folders
/ios
/android

# Ralph (ralph-cursor)
/ralph/projects/*/logs/
/ralph/projects/*/status.json

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Playtest report output (generated, not committed)
tests/e2e/reports/screenshots/*.png
tests/e2e/reports/playtest-report.html
tests/e2e/reports/playtest-results.json

# Visual test output (manual-review screenshots, generated per run)
tests/visual/screenshots/*.png
tests/e2e/screenshots/*.png

# E2E local config (copy from config/e2e.example.json)
config/e2e.json

# Local integration staging
/pending-integration/

# Local task-orchestration scratch data
/.ralph-tui/

# Nested clone (do not commit)
/syntheteria/

# Brainstorming companion cache
.superpowers/
.claude/worktrees/
